---
const GTM_ID = import.meta.env.PUBLIC_GTM_ID ?? 'GTM-XXXX';
---

<script type="text/partytown" is:inline src={`https://www.googletagmanager.com/gtag/js?id=${GTM_ID}`}></script>
<script type="text/partytown" define:vars={{ GTM_ID }} is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', GTM_ID);
</script>